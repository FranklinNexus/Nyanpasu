# Copy to keystore.properties and fill in values for release signing.
# Do NOT commit keystore.properties or your .jks file to git.
#
# GitHub Release (tag v*.*.*) also needs repository secrets:
#   KEYSTORE_BASE64  — base64-encoded release.jks
#   KEYSTORE_PASSWORD, KEY_ALIAS, KEY_PASSWORD

storeFile=release.jks
storePassword=your_store_password
keyAlias=your_key_alias
keyPassword=your_key_password
